{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "server.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:accounts": "jest __tests__/accounts.test.js",
    "test:auth": "jest __tests__/auth.test.js",
    "test:categories": "jest __tests__/categories.test.js",
    "start": "node server.js",
    "dev": "nodemon server.js",
    "postinstall": "npx puppeteer browsers install chrome"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "routes/**/*.js",
      "models/**/*.js",
      "middleware/**/*.js",
      "services/**/*.js",
      "!node_modules/**"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "bcryptjs": "^3.0.2",
    "bull": "^4.16.5",
    "cheerio": "^1.1.0",
    "chrome-aws-lambda": "^10.1.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "express-session": "^1.18.2",
    "googleapis": "^153.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.16.4",
    "openai": "^5.10.1",
    "puppeteer": "^24.15.0",
    "puppeteer-core": "^10.4.0"
  },
  "devDependencies": {
    "jest": "^30.0.5",
    "mongodb-memory-server": "^10.1.4",
    "nodemon": "^3.1.10",
    "supertest": "^7.1.4"
  }
}
